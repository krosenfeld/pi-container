#!/usr/bin/env bash
# Run the pi coding agent against any directory.
# Place this script (or a symlink to it) somewhere on your PATH,
# e.g.:  ln -s "$(pwd)/pie" /usr/local/bin/pie
#
# Usage:
#   pie                          # interactive TUI in the current directory
#   pie "Create a snake game"    # one-off prompt
#   pie --version                # pass any pi flags

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR points at the real repo, not e.g. ~/.local/bin
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Load environment variables from the .env file that lives next to this script
if [ -f "$SCRIPT_DIR/.env" ]; then
  set -a
  # shellcheck source=/dev/null
  source "$SCRIPT_DIR/.env"
  set +a
else
  echo "Warning: no .env file found in $SCRIPT_DIR — API keys / git identity may be missing." >&2
fi

# Only allocate a TTY / attach stdin when both stdin and stdout are attached to
# a terminal. This keeps the interactive TUI working while still allowing
# scripted / CI use like `pie --version` or piping input.
DOCKER_TTY_FLAGS=()
if [ -t 0 ] && [ -t 1 ]; then
  DOCKER_TTY_FLAGS+=(-i -t)
elif [ ! -t 0 ]; then
  # stdin is a pipe/file — keep it attached so data can flow in, but no TTY.
  DOCKER_TTY_FLAGS+=(-i)
fi

docker run --rm ${DOCKER_TTY_FLAGS[@]+"${DOCKER_TTY_FLAGS[@]}"} \
  -e GITHUB_TOKEN \
  -e ANTHROPIC_API_KEY \
  -e OPENAI_API_KEY \
  -e GIT_AUTHOR_NAME="${GIT_NAME:-}" \
  -e GIT_AUTHOR_EMAIL="${GIT_EMAIL:-}" \
  -e GIT_COMMITTER_NAME="${GIT_NAME:-}" \
  -e GIT_COMMITTER_EMAIL="${GIT_EMAIL:-}" \
  -e HOME=/home/node \
  -e GIT_CONFIG_COUNT=3 \
  -e GIT_CONFIG_KEY_0="credential.https://github.com.helper" \
  -e "GIT_CONFIG_VALUE_0=!/usr/bin/gh auth git-credential" \
  -e GIT_CONFIG_KEY_1="user.signingkey" \
  -e "GIT_CONFIG_VALUE_1=${GIT_GPG_KEY:-}" \
  -e GIT_CONFIG_KEY_2="commit.gpgsign" \
  -e "GIT_CONFIG_VALUE_2=${GIT_GPG_SIGN:-false}" \
  -v "$(pwd):/workspace" \
  -v "${SKILLS_DIR:-$HOME/.agents/skills}:/home/node/.agents/skills:ro" \
  -v "$SCRIPT_DIR/.pi-data:/home/node/.pi" \
  --user "$(id -u):$(id -g)" \
  local/pi-coding-agent:latest \
  "$@"
