# ==========================================
# Docker Configuration
# ==========================================
# User ID and Group ID mapping for file permissions on Linux.
# Run `id -u` and `id -g` to find your values.
# NOTE: do NOT name these UID/GID — `UID` is readonly in bash and will
# break any script that sources this file with `set -e`.
HOST_UID=1000
HOST_GID=1000

GITHUB_TOKEN=

# ==========================================
# LLM Provider API Keys
# ==========================================
# Set one or both depending on which models you want to use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Git Identity
GIT_NAME=Your Name
GIT_EMAIL=your.email@example.com

GIT_GPG_KEY=your_gpg_key
GIT_GPG_SIGN=false

# ==========================================
# Skills Directory (mounted read-only)
# ==========================================
# Path to your local pi agent skills directory
# SKILLS_DIR=~/.agents/skills
