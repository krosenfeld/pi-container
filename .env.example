# ==========================================
# Docker Configuration
# ==========================================
# User ID and Group ID mapping for file permissions on Linux
# Run `id -u` and `id -g` to find your values.
UID=1000
GID=1000

GITHUB_TOKEN=
# Git Identity
GIT_NAME=Your Name
GIT_EMAIL=your.email@example.com

GIT_GPG_KEY=your_gpg_key
GIT_GPG_SIGN=false

# ==========================================
# Skills Directory (mounted read-only)
# ==========================================
# Path to your local pi agent skills directory
# SKILLS_DIR=~/.agents/skills
